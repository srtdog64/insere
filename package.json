{
  "name": "@exornea/insere",
  "version": "0.1.0",
  "description": "Small cooperative scheduler for frame-aware TypeScript apps.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/srtdog64/insere.git"
  },
  "bugs": {
    "url": "https://github.com/srtdog64/insere/issues"
  },
  "homepage": "https://github.com/srtdog64/insere#readme",
  "keywords": [
    "scheduler",
    "cooperative",
    "frame",
    "cancellation",
    "typescript",
    "task",
    "runtime",
    "editor",
    "game"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./api": {
      "types": "./dist/api.d.ts",
      "default": "./dist/api.js"
    },
    "./host": {
      "types": "./dist/host.d.ts",
      "default": "./dist/host.js"
    },
    "./mailbox": {
      "types": "./dist/mailbox.d.ts",
      "default": "./dist/mailbox.js"
    },
    "./event-bus": {
      "types": "./dist/event-bus.d.ts",
      "default": "./dist/event-bus.js"
    },
    "./supervision": {
      "types": "./dist/supervision.d.ts",
      "default": "./dist/supervision.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "docs",
    "benchmark",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "benchmark": "npm run build && node benchmark/compare.mjs",
    "benchmark:geukbit": "npm run build && node benchmark/geukbit-scale.mjs",
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "check:publish": "npm run build && npm test && npm run smoke:exports",
    "pack:check": "npm pack --dry-run",
    "prepack": "npm run build",
    "prebuild": "rimraf dist",
    "prepublishOnly": "npm run check:publish",
    "smoke:exports": "node scripts/smoke-exports.mjs",
    "stress:geukbit": "vitest run test/geukbit-scale.test.ts",
    "verify:geukbit": "npm run stress:geukbit && npm run benchmark:geukbit",
    "test": "vitest run",
    "check": "npm run build && npm test && npm run smoke:exports && npm run pack:check"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  }
}
